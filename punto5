using System;

namespace punto5
{
    class Program
    {
        static void Main(string[] args)
        {
            string continuar = "S";

            while (continuar.ToUpper() == "S")
            {
                int turno = -1;

                while (turno <= 0)
                {
                    Console.Write("Ingrese el número de turno (mayor a 0): ");
                    turno = int.Parse(Console.ReadLine());

                    if (turno <= 0)
                    {
                        Console.WriteLine("Error: El turno debe ser un número positivo.");
                    }
                }

                Console.WriteLine("Turno #" + turno + " registrado con éxito.");

                Console.Write("¿desea continuar? (S/N): ");
                continuar = Console.ReadLine();
            }

            Console.WriteLine("finalizado.");
        }
    }
}
